<!DOCTYPE html>
<html lang="en">
<head>
    <!-- meta, títulos, estilos… -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
</head>
<body>
    <div class="container-fluid">
        <div class="row g-0">
            <!-- Sidebar fijo de ancho 270px: -->
            <nav class="col-auto sidebar d-flex flex-column p-3">
                <div class="logo-container mb-4">
                    <a asp-controller="Home" asp-action="Index" class="d-flex align-items-center text-decoration-none">
                        <img src="~/images/logo.png" width="80" alt="Logo" />
                        <span class="ms-2 fs-4 text-white">Inventar.io</span>
                    </a>
                </div>
                <ul class="nav nav-pills flex-column">
                    <li class="nav-item"><a asp-controller="Producto" asp-action="Index" class="nav-link text-white">Producto</a></li>
                    <li class="nav-item"><a asp-controller="Categoria" asp-action="Index" class="nav-link text-white">Categoría</a></li>
                    <li class="nav-item"><a asp-controller="Pedido" asp-action="Index" class="nav-link text-white">Pedido</a></li>
                    <li class="nav-item"><a asp-controller="Cliente" asp-action="Index" class="nav-link text-white">Cliente</a></li>
                </ul>
            </nav>

            <!-- Contenido principal ocupa el resto de la pantalla -->
            <main class="col p-0">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top text-center py-3">
        &copy; 2025 – Inventar.io
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
