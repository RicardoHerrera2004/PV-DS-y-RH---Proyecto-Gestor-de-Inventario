@model PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.Pedido

@{
    ViewData["Title"] = "Crear Pedido";
}

<h1>Crear Nuevo Pedido</h1>
<p>Con esta opción, puedes agregar un nuevo pedido al sistema completando un formulario con detalles como la fecha del pedido, el total, el estado y el cliente.</p>
<hr />

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Resumen de validación -->
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Campo Fecha del Pedido -->
                    <div class="mb-3">
                        <label asp-for="FechaPedido" class="form-label fw-semibold">Fecha del Pedido</label>
                        <input asp-for="FechaPedido" class="form-control" type="date" />
                        <span asp-validation-for="FechaPedido" class="text-danger small"></span>
                    </div>

                    <!-- Campo Total -->
                    <div class="mb-3">
                        <label asp-for="Total" class="form-label fw-semibold">Total</label>
                        <input asp-for="Total" class="form-control" type="number" step="0.01" placeholder="Ejemplo: 150.75" />
                        <span asp-validation-for="Total" class="text-danger small"></span>
                    </div>

                    <!-- Campo Estado -->
                    <div class="mb-3">
                        <label asp-for="Estado" class="form-label fw-semibold">Estado</label>
                        <input asp-for="Estado" class="form-control" placeholder="Ejemplo: Pendiente, Enviado" />
                        <span asp-validation-for="Estado" class="text-danger small"></span>
                    </div>

                    <!-- Campo Cliente -->
                    <div class="mb-3">
                        <label asp-for="ClienteId" class="form-label fw-semibold">Cliente</label>
                        <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId">
                            <option value="">-- Selecciona un cliente --</option>
                        </select>
                        <span asp-validation-for="ClienteId" class="text-danger small"></span>
                    </div>

                    <!-- Botón Crear -->
                    <div class="d-flex justify-content-between mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-2"></i>Crear Pedido
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Botón Regresar -->
<div class="mt-3">
    <a class="btn btn-outline-secondary d-inline-flex align-items-center" asp-action="Index">
        Regresar a la Lista
        <i class="bi bi-arrow-left-short" style="font-size: 20px;"></i>
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
