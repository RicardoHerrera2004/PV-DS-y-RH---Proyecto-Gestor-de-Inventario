@model PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.Pedido

@{
    ViewData["Title"] = "Editar Pedido";
}

<h1 class="mb-4">Editar Pedido</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="FechaPedido" class="form-label fw-semibold">
                    <i class="bi bi-calendar-date me-1"></i> Fecha del Pedido
                </label>
                <input asp-for="FechaPedido" class="form-control" placeholder="Ej. 2025-04-30" />
                <span asp-validation-for="FechaPedido" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Total" class="form-label fw-semibold">
                    <i class="bi bi-cash-coin me-1"></i> Total
                </label>
                <input asp-for="Total" class="form-control" placeholder="Ej. 125.99" />
                <span asp-validation-for="Total" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Estado" class="form-label fw-semibold">
                    <i class="bi bi-flag-fill me-1"></i> Estado
                </label>
                <input asp-for="Estado" class="form-control" placeholder="Ej. Entregado, Pendiente..." />
                <span asp-validation-for="Estado" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ClienteId" class="form-label fw-semibold">
                    <i class="bi bi-person-fill me-1"></i> Cliente
                </label>
                <select asp-for="ClienteId" class="form-select" asp-items="ViewBag.ClienteId"></select>
                <span asp-validation-for="ClienteId" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save-fill me-1"></i> Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

