@model PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.Categoria

@{
    ViewData["Title"] = "Crear Categoría";
}

<h1>Crear Nueva Categoría</h1>
<p>Con esta opción, puedes agregar una nueva categoría al sistema completando un formulario con detalles como el nombre y la descripción.</p>
<hr />

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Resumen de validación -->
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Campo Nombre -->
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Nombre de la categoría" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <!-- Campo Descripción -->
                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-semibold">Descripción</label>
                        <input asp-for="Descripcion" class="form-control" placeholder="Descripción de la categoría" />
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>

                    <!-- Botón Crear -->
                    <div class="d-flex justify-content-between mt-4">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-2"></i>Crear Categoría
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Botón Regresar -->
<div class="mt-3">
    <a class="btn btn-outline-secondary d-inline-flex align-items-center" asp-action="Index">
        Regresar a la Lista
        <i class="bi bi-arrow-left-short" style="font-size: 20px;"></i>
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
