@model PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.Cliente

@{
    ViewData["Title"] = "Crear Cliente";
}

<h1>Crear Nuevo Cliente</h1>
<p>Con esta opción, puedes agregar los detalles de un nuevo cliente al sistema. Completa el formulario con la información correspondiente.</p>
<hr />

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <!-- Resumen de validación -->
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Campo Nombre -->
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-semibold">Nombre</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre del cliente" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <!-- Campo Apellido -->
                    <div class="mb-3">
                        <label asp-for="Apellido" class="form-label fw-semibold">Apellido</label>
                        <input asp-for="Apellido" class="form-control" placeholder="Ingrese el apellido del cliente" />
                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                    </div>

                    <!-- Campo Teléfono -->
                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label fw-semibold">Teléfono</label>
                        <input asp-for="Telefono" class="form-control" placeholder="Número de teléfono del cliente" />
                        <span asp-validation-for="Telefono" class="text-danger small"></span>
                    </div>

                    <!-- Campo Fecha de Registro -->
                    <div class="mb-3">
                        <label asp-for="FechaRegistro" class="form-label fw-semibold">Fecha de Registro</label>
                        <input asp-for="FechaRegistro" class="form-control" placeholder="Fecha en la que se registró el cliente" />
                        <span asp-validation-for="FechaRegistro" class="text-danger small"></span>
                    </div>

                    <!-- Botón Crear -->
                    <div class="d-flex justify-content-between mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-2"></i>Crear Cliente
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Botón Regresar -->
<div class="mt-3">
    <a class="btn btn-outline-secondary d-inline-flex align-items-center" asp-action="Index">
        Regresar a la Lista
        <i class="bi bi-arrow-left-short" style="font-size: 20px;"></i>
    </a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
