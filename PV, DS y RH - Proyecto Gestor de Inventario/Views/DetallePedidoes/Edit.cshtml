@model PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.DetallePedido

@{
    ViewData["Title"] = "Editar Detalle de Pedido";
}

<h1 class="mb-4">Editar Detalle de Pedido</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="PrecioOriginal" class="form-label fw-semibold">
                    <i class="bi bi-currency-dollar me-1"></i> Precio Original
                </label>
                <input asp-for="PrecioOriginal" class="form-control" placeholder="Ej. 10.50" />
                <span asp-validation-for="PrecioOriginal" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PrecioVendido" class="form-label fw-semibold">
                    <i class="bi bi-tag-fill me-1"></i> Precio Vendido
                </label>
                <input asp-for="PrecioVendido" class="form-control" placeholder="Ej. 9.99" />
                <span asp-validation-for="PrecioVendido" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Obervacion" class="form-label fw-semibold">
                    <i class="bi bi-chat-left-text-fill me-1"></i> Observación
                </label>
                <input asp-for="Obervacion" class="form-control" placeholder="Observaciones del pedido" />
                <span asp-validation-for="Obervacion" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PedidoId" class="form-label fw-semibold">
                    <i class="bi bi-list-check me-1"></i> Pedido
                </label>
                <select asp-for="PedidoId" class="form-select" asp-items="ViewBag.PedidoId"></select>
                <span asp-validation-for="PedidoId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ProductoId" class="form-label fw-semibold">
                    <i class="bi bi-box-seam me-1"></i> Producto
                </label>
                <select asp-for="ProductoId" class="form-select" asp-items="ViewBag.ProductoId"></select>
                <span asp-validation-for="ProductoId" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save-fill me-1"></i> Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
