@model IEnumerable<PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.DetallePedido>

@{
    ViewData["Title"] = "Detalles del Pedido";
}

<h1>Detalles del Pedido</h1>

<!-- Botón para crear nuevo detalle -->
<p>
    <a class="btn btn-primary d-inline-flex align-items-center" asp-action="Create">
        Crear Nuevo Detalle
        <i class="bi bi-plus-circle ms-2" style="font-size: 20px;"></i>
    </a>
</p>

<!-- Tabla de detalles del pedido -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().PrecioOriginal)</th>
            <th>@Html.DisplayNameFor(model => model.First().PrecioVendido)</th>
            <th>@Html.DisplayNameFor(model => model.First().Obervacion)</th>
            <th>ID Pedido</th>
            <th>Producto</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.PrecioOriginal)</td>
                <td>@Html.DisplayFor(modelItem => item.PrecioVendido)</td>
                <td>@Html.DisplayFor(modelItem => item.Obervacion)</td>
                <td>@Html.DisplayFor(modelItem => item.Pedido.Id)</td>
                <td>@Html.DisplayFor(modelItem => item.Producto.Nombre)</td>
                <td class="text-center">
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.Id">
                        <i class="bi bi-pencil-square"></i> Editar
                    </a>
                    <a class="btn btn-info btn-sm" asp-action="Details" asp-route-id="@item.Id">
                        <i class="bi bi-eye"></i> Detalles
                    </a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id" onclick="return confirm('¿Estás seguro de eliminar este detalle?')">
                        <i class="bi bi-trash"></i> Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
