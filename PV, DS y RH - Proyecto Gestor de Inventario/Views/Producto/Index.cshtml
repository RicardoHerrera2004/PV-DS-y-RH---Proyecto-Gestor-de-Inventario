@model IEnumerable<PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h1>Productos</h1>

<!-- Botón para crear nuevo -->
<p>
    <a class="btn btn-primary d-inline-flex align-items-center" asp-action="Create">
        Crear Nuevo Producto
        <i class="bi bi-plus-circle ms-2" style="font-size: 20px;"></i>
    </a>
</p>

<!-- Tabla de productos -->
<table class="table table-striped">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().Nombre)</th>
            <th>@Html.DisplayNameFor(model => model.First().Descripcion)</th>
            <th>@Html.DisplayNameFor(model => model.First().Precio)</th>
            <th>@Html.DisplayNameFor(model => model.First().FechaRegistro)</th>
            <th>@Html.DisplayNameFor(model => model.First().Cantidad)</th>
            <th>@Html.DisplayNameFor(model => model.First().Categoria.Nombre)</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                <td>@Html.DisplayFor(modelItem => item.Precio)</td>
                <td>@Html.DisplayFor(modelItem => item.FechaRegistro)</td>
                <td>@Html.DisplayFor(modelItem => item.Cantidad)</td>
                <td>@Html.DisplayFor(modelItem => item.Categoria.Nombre)</td>
                <td class="text-center">
                    <a class="btn btn-warning btn-sm" asp-action="Edit" asp-route-id="@item.Id">
                        <i class="bi bi-pencil-square"></i> Editar
                    </a>
                    <a class="btn btn-danger btn-sm" asp-action="Delete" asp-route-id="@item.Id">
                        <i class="bi bi-trash"></i> Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
