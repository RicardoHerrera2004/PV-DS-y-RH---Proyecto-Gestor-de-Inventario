@model PV__DS_y_RH___Proyecto_Gestor_de_Inventario.Models.Producto

@{
    ViewData["Title"] = "Editar Producto";
}

<h1 class="mb-4">Editar Producto</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-semibold">
                    <i class="bi bi-box me-1"></i> Nombre del Producto
                </label>
                <input asp-for="Nombre" class="form-control" placeholder="Ej. Smartphone" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold">
                    <i class="bi bi-pencil-fill me-1"></i> Descripción
                </label>
                <input asp-for="Descripcion" class="form-control" placeholder="Ej. Smartphone de última generación" />
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Precio" class="form-label fw-semibold">
                    <i class="bi bi-cash-coin me-1"></i> Precio
                </label>
                <input asp-for="Precio" class="form-control" placeholder="Ej. 199.99" />
                <span asp-validation-for="Precio" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FechaRegistro" class="form-label fw-semibold">
                    <i class="bi bi-calendar-date me-1"></i> Fecha de Registro
                </label>
                <input asp-for="FechaRegistro" class="form-control" placeholder="Ej. 2025-04-30" />
                <span asp-validation-for="FechaRegistro" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Cantidad" class="form-label fw-semibold">
                    <i class="bi bi-archive me-1"></i> Cantidad
                </label>
                <input asp-for="Cantidad" class="form-control" placeholder="Ej. 100" />
                <span asp-validation-for="Cantidad" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoriaId" class="form-label fw-semibold">
                    <i class="bi bi-tag me-1"></i> Categoría
                </label>
                <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.CategoriaId"></select>
                <span asp-validation-for="CategoriaId" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between mt-4">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-arrow-left-circle me-1"></i> Volver a la lista
                </a>
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save-fill me-1"></i> Guardar cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
