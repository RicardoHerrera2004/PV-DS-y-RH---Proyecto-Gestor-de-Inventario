@{
    ViewData["Title"] = "Acerca de Nosotros";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            margin: 0;
            padding: 0;
            background-color: floralwhite;
            color: #333;
        }

        /* Eliminar márgenes por defecto y asegurarse de que el body ocupa todo el ancho */
        html, body {
            overflow-x: hidden;
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
        }

        /* Contenedor general */
        .container {
            width: 100%;
            margin: 0;
            padding: 0;
        }

        /* Header con la imagen */
        header {
            margin-left: 0;
            width: 112%;
            height: 30vh;
            overflow: hidden;
            position: relative;
            z-index: 0;
        }

            header img {
                width: 100%;
                height: 100%; /* Ocupa el 100% de la altura disponible */
                object-fit: cover; /* Ajusta la imagen para que cubra todo el espacio */
                margin: 0;
                padding: 0;
            }

            /* El título dentro de la imagen */
            header h1 {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                color: white;
                font-family: "Dancing Script", cursive;
                font-optical-sizing: auto;
                font-weight: <weight>;
                font-style: normal;
                font-size: 4.5em;
                text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            }

        section {
            margin: 40px 0;
        }

        .image-section {
            display: flex;
            justify-content: center; /* Centra horizontalmente */
            align-items: center; /* Centra verticalmente dentro del contenedor */
            gap: 30px;
            margin-top: 40px;
            flex-wrap: wrap; /* Para que no se rompa en pantallas pequeñas */
        }

            .image-section img {
                width: 200px;
                height: 200px;
                border-radius: 50%;
                object-fit: cover;
                border: 4px solid #2C3E50;
                box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
            }

        .content-section {
            display: flex;
            justify-content: space-between;
            gap: 30px;
        }

            .content-section .text {
                flex: 1;
            }

                .content-section .text h2 {
                    font-size: 2em;
                    color: #34495E;
                }

                .content-section .text p {
                    font-size: 1.1em;
                    line-height: 1.6;
                }

        footer {
            text-align: center;
            padding: 20px;
            background-color: #2C3E50;
            color: #fff;
            margin-top: 50px;
        }
    </style>
</head>

<body>

    <div class="container">
        <!-- Header Section -->
        <header>
            <img src="@Url.Content("~/images/como-escribir-web-sobre-nosotros.jpg")" alt="acerca de nosotros" />

            <h1>Acerca de Nosotros</h1>
        </header>


        <!-- Content Section -->
        <section class="content-section">
            <div class="container py-5">
                <!-- Sección 1 -->
                <div class="row featurette align-items-center mb-5">
                    <div class="col-md-7">
                        <h2 class="featurette-heading fw-bold">
                            ¿Quiénes somos? <span class="text-muted">Amigos, soñadores y desarrolladores.</span>
                        </h2>
                        <p class="lead">
                            Somos <strong>UniDevs</strong>, un grupo de amigos que se conocieron en la universidad con una pasión en común: la programación.
                            Lo que comenzó como tareas y desvelos, hoy es un equipo unido por las ideas y el código.
                        </p>
                    </div>
                    <div class="col-md-5">
                        <img src="@Url.Content("~/images/Unidev.jpg")"
                             class="img-fluid rounded-circle shadow mx-auto d-block"
                             style="max-width: 300px;"
                             alt="Unidev equipo">
                    </div>
                </div>

                <hr class="featurette-divider">

                <!-- Sección 2 -->
                <div class="row featurette align-items-center mb-5">
                    <div class="col-md-7 order-md-2">
                        <h2 class="featurette-heading fw-bold">
                            Nuestro origen <span class="text-muted">en los pasillos universitarios.</span>
                        </h2>
                        <p class="lead">
                            UniDevs nació entre clases, cafeterías y muchas líneas de código. Descubrimos que trabajando juntos aprendíamos más y mejor.
                        </p>
                    </div>
                    <div class="col-md-5 order-md-1">
                        <img src="@Url.Content("~/images/Unidev Grupo.jpg")" class="img-fluid rounded-circle shadow"
                             style="max-width: 270px; " alt="Unidevs grupo">
                    </div>
                </div>

                <hr class="featurette-divider">

                <!-- Sección 3 -->
                <div class="row featurette align-items-center mb-5">
                    <div class="col-md-7">
                        <h2 class="featurette-heading fw-bold">
                            ¿Qué hacemos? <span class="text-muted">Soluciones con propósito.</span>
                        </h2>
                        <p class="lead">
                            Nos dedicamos al desarrollo de software que mejora procesos y simplifica tareas. Cada solución busca ser útil, intuitiva y bien pensada.
                        </p>
                    </div>
                    <div class="col-md-5">
                        <img src="https://images.griddo.universitatcarlemany.com/metodologias-de-desarrollo-de-software-ucma-1" class="img-fluid rounded-circle shadow"
                             style="max-width: 500px;" 
                             alt="proyectos">
                    </div>
                </div>

                <hr class="featurette-divider">

                <!-- Sección 4 -->
                <div class="row featurette align-items-center mb-5">
                    <div class="col-md-7 order-md-2">
                        <h2 class="featurette-heading fw-bold">
                            Nuestro propósito <span class="text-muted">y nuestra pasión.</span>
                        </h2>
                        <p class="lead">
                            Queremos crecer, aprender y construir, siempre con la amistad como base. Porque cuando disfrutas lo que haces, el resultado se nota.
                        </p>
                    </div>
                    <div class="col-md-5 order-md-1">
                        <img src="https://grupovertice.com/blog/wp-content/uploads/2016/10/trabajo-cool2.jpg" class="img-fluid rounded-circle shadow"
                             style="max-width: 500px;" alt="propósito">
                    </div>
                </div>
            </div>

        </section>
    </div>


</body>
</html>
